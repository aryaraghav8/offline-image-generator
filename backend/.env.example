# ── Server ──────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
OUTPUT_DIR=outputs
DATA_DIR=data

# ── Pollinations (default provider) ─────────────────────────────────────────
POLLINATIONS_API_KEY=

# ── Generation defaults ──────────────────────────────────────────────────────
IMAGE_MODEL=flux

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=changeme          # protects POST/PUT/DELETE on /api/admin/*

# ── Storage cleanup ──────────────────────────────────────────────────────────
STORAGE_TOTAL_BYTES=536870912000    # 500 GB nominal capacity shown in admin UI
